a:TemplateStyles:r1126788409" /><div class="plainlist"><ul><li><div class="nowrap"><span style="font-style:normal;vertical-align:top;"><a href="/wiki/South_Asia" title="South Asia">SA</a>/<a href="/wiki/Southeast_Asia" title="Southeast Asia">SEA</a>:</span> <span style="width:71%; display:inline-block;" class="wrap"><a href="/wiki/Medialink" title="Medialink">Medialink</a></span></div></li></ul></div></li></ul></div></td></tr><tr><th scope="row" class="infobox-label">Released</th><td class="infobox-data"><span class="nowrap"> June 28, 2025 </span> – <span class="nowrap"> August 2, 2025</span></td></tr><tr><th scope="row" class="infobox-label">Episodes</th><td class="infobox-data">6</td></tr>
